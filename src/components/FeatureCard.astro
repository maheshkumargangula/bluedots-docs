---
interface Props {
  title: string;
  icon: string;
  color: 'blue' | 'pink' | 'purple' | 'orange' | 'green';
}
const { title, icon, color } = Astro.props;
---

<div class:list={['feature-card', `feature-card--${color}`]}>
  <div class="feature-icon" aria-hidden="true">{icon}</div>
  <h3 class="feature-title">{title}</h3>
  <div class="feature-body"><slot /></div>
</div>

<style>
  .feature-card {
    --fc: var(--dot-blue);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.5rem;
    border-radius: 1rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-top: 4px solid var(--fc);
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .feature-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 28px color-mix(in srgb, var(--fc) 22%, transparent);
  }
  .feature-card--blue   { --fc: var(--dot-blue); }
  .feature-card--pink   { --fc: var(--dot-pink); }
  .feature-card--purple { --fc: var(--dot-purple); }
  .feature-card--orange { --fc: var(--dot-orange); }
  .feature-card--green  { --fc: var(--dot-green); }

  .feature-icon {
    font-size: 1.625rem;
    line-height: 1;
    width: 3rem;
    height: 3rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.625rem;
    background: color-mix(in srgb, var(--fc) 12%, transparent);
    flex-shrink: 0;
  }

  .feature-title {
    font-size: 1.125rem;
    font-weight: 700;
    color: var(--fc);
    margin: 0;
    border: none;
    padding: 0;
    line-height: 1.3;
  }

  .feature-body {
    font-size: 0.9375rem;
    color: var(--sl-color-gray-2);
    line-height: 1.6;
    margin: 0;
  }
  .feature-body :global(p) {
    margin: 0;
  }
  .feature-body :global(strong) {
    color: var(--sl-color-text);
    font-weight: 600;
  }
</style>
