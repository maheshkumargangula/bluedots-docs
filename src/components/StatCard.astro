---
type LucideIcon = 'briefcase' | 'zap' | 'mic' | 'building-2';
type CardColor = 'blue' | 'green' | 'purple' | 'orange' | 'pink' | 'brown' | 'accent';

interface Props {
  value: string;
  label: string;
  color?: CardColor;
  icon?: LucideIcon;
}
const { value, label, color = 'accent', icon } = Astro.props;

const paths: Record<LucideIcon, string> = {
  'briefcase':  `<rect width="20" height="14" x="2" y="7" rx="2" ry="2"/><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>`,
  'zap':        `<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>`,
  'mic':        `<path d="M12 2a3 3 0 0 0-3 3v7a3 3 0 0 0 6 0V5a3 3 0 0 0-3-3Z"/><path d="M19 10v2a7 7 0 0 1-14 0v-2"/><line x1="12" x2="12" y1="19" y2="22"/>`,
  'building-2': `<path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h2"/><path d="M18 9h2a2 2 0 0 1 2 2v9a2 2 0 0 1-2 2h-2"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/>`,
};
---

<div class:list={['sc', `sc--${color}`]}>
  {icon && (
    <div class="sc-icon">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="18" height="18"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        aria-hidden="true"
        set:html={paths[icon]}
      />
    </div>
  )}
  <div class="sc-value">{value}</div>
  <div class="sc-label">{label}</div>
</div>

<style>
  .sc {
    --from: #eff6ff;
    --to:   #dbeafe;
    --bd:   rgba(29, 108, 242, 0.2);
    --ic:   #1d6cf2;
    --ibg:  rgba(29, 108, 242, 0.12);
    --glow: rgba(29, 108, 242, 0.2);

    background: linear-gradient(145deg, var(--from) 0%, var(--to) 100%);
    border: 1px solid var(--bd);
    border-radius: 1rem;
    padding: 1.375rem 1.5rem 1.625rem;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.06);
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    height: 100%;
    transition:
      transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1),
      box-shadow 0.22s ease,
      border-color 0.18s ease;
  }

  .sc:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 32px var(--glow), 0 4px 8px rgba(0,0,0,0.06);
    border-color: var(--ic);
  }

  /* ── colour variants (light) ── */
  .sc--blue   { --from:#eff6ff; --to:#dbeafe; --bd:rgba(29,108,242,.22); --ic:#1d6cf2; --ibg:rgba(29,108,242,.14); --glow:rgba(29,108,242,.22); }
  .sc--green  { --from:#f0fdf4; --to:#dcfce7; --bd:rgba(22,163,74,.22);  --ic:#16a34a; --ibg:rgba(22,163,74,.14);  --glow:rgba(22,163,74,.22); }
  .sc--purple { --from:#faf5ff; --to:#ede9fe; --bd:rgba(124,58,237,.22); --ic:#7c3aed; --ibg:rgba(124,58,237,.14); --glow:rgba(124,58,237,.22); }
  .sc--orange { --from:#fff7ed; --to:#ffedd5; --bd:rgba(234,88,12,.22);  --ic:#ea580c; --ibg:rgba(234,88,12,.14);  --glow:rgba(234,88,12,.22); }
  .sc--pink   { --from:#fdf2f8; --to:#fce7f3; --bd:rgba(203,57,130,.22); --ic:#be185d; --ibg:rgba(203,57,130,.14); --glow:rgba(203,57,130,.22); }
  .sc--brown  { --from:#fdf8f1; --to:#fef3c7; --bd:rgba(119,65,27,.22);  --ic:#92400e; --ibg:rgba(119,65,27,.14);  --glow:rgba(119,65,27,.22); }
  .sc--accent { --from:#eff6ff; --to:#dbeafe; --bd:rgba(29,108,242,.22); --ic:#1d6cf2; --ibg:rgba(29,108,242,.14); --glow:rgba(29,108,242,.22); }

  /* ── dark mode ── */
  :root[data-theme='dark'] .sc--blue   { --from:rgba(29,108,242,.1); --to:rgba(29,108,242,.05); --bd:rgba(29,108,242,.3);  --ic:#93bbff; --ibg:rgba(29,108,242,.18); --glow:rgba(29,108,242,.3); }
  :root[data-theme='dark'] .sc--green  { --from:rgba(22,163,74,.1);  --to:rgba(22,163,74,.05);  --bd:rgba(22,163,74,.3);   --ic:#86efac; --ibg:rgba(22,163,74,.18);  --glow:rgba(22,163,74,.3); }
  :root[data-theme='dark'] .sc--purple { --from:rgba(124,58,237,.1); --to:rgba(124,58,237,.05); --bd:rgba(124,58,237,.3);  --ic:#c4b5fd; --ibg:rgba(124,58,237,.18); --glow:rgba(124,58,237,.3); }
  :root[data-theme='dark'] .sc--orange { --from:rgba(234,88,12,.1);  --to:rgba(234,88,12,.05);  --bd:rgba(234,88,12,.3);   --ic:#fdba74; --ibg:rgba(234,88,12,.18);  --glow:rgba(234,88,12,.3); }
  :root[data-theme='dark'] .sc--pink   { --from:rgba(203,57,130,.1); --to:rgba(203,57,130,.05); --bd:rgba(203,57,130,.3);  --ic:#f9a8d4; --ibg:rgba(203,57,130,.18); --glow:rgba(203,57,130,.3); }
  :root[data-theme='dark'] .sc--brown  { --from:rgba(119,65,27,.1);  --to:rgba(119,65,27,.05);  --bd:rgba(119,65,27,.3);   --ic:#d97706; --ibg:rgba(119,65,27,.18);  --glow:rgba(119,65,27,.3); }

  /* ── icon badge ── */
  .sc-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    background: var(--ibg);
    color: var(--ic);
    margin-bottom: 0.25rem;
    transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .sc:hover .sc-icon {
    transform: scale(1.12) rotate(-4deg);
  }

  /* ── value ── */
  .sc-value {
    font-size: clamp(1.75rem, 3vw, 2.5rem);
    font-weight: 800;
    line-height: 1.05;
    letter-spacing: -0.04em;
    color: var(--ic);
  }

  /* ── label ── */
  .sc-label {
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--sl-color-gray-2);
  }
</style>
