---
import { Icon } from '@astrojs/starlight/components';

interface Props {
  title: string;
  description: string;
  href: string;
  icon: Parameters<typeof Icon>[0]['name'];
}
const { title, description, href, icon } = Astro.props;
---

<a href={href} class="nav-card">
  <div class="nav-icon">
    <Icon name={icon} size="1.125rem" />
  </div>
  <div class="nav-body">
    <span class="nav-title">{title}</span>
    <span class="nav-desc">{description}</span>
  </div>
  <Icon name="right-arrow" size="1rem" class="nav-chevron" />
</a>

<style>
  .nav-card {
    display: flex;
    align-items: center;
    gap: 0.875rem;
    padding: 1.125rem 1.25rem;
    border-radius: 0.75rem;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg-nav);
    text-decoration: none;
    box-shadow:
      0 1px 3px 0 rgba(0, 0, 0, 0.06),
      0 1px 2px 0 rgba(0, 0, 0, 0.04);
    transition: box-shadow 0.2s ease, transform 0.2s ease, background 0.15s ease;
  }

  .nav-card:hover {
    background: var(--sl-color-accent-low);
    box-shadow:
      0 4px 6px -1px rgba(0, 0, 0, 0.08),
      0 2px 4px -2px rgba(0, 0, 0, 0.05);
    transform: translateY(-1px);
  }

  :root[data-theme='dark'] .nav-card:hover {
    background: rgba(255, 255, 255, 0.04);
  }

  .nav-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    border-radius: 0.5rem;
    border: 1px solid var(--sl-color-hairline);
    background: var(--sl-color-bg);
    color: var(--sl-color-accent);
    flex-shrink: 0;
    transition: background 0.15s ease, color 0.15s ease;
  }

  .nav-card:hover .nav-icon {
    background: var(--sl-color-accent);
    color: #fff;
    border-color: var(--sl-color-accent);
  }

  .nav-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .nav-title {
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--sl-color-text);
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  .nav-desc {
    font-size: 0.8125rem;
    color: var(--sl-color-gray-2);
    line-height: 1.5;
  }

  .nav-chevron {
    color: var(--sl-color-gray-3);
    flex-shrink: 0;
    transition: transform 0.18s ease, color 0.15s ease;
  }

  .nav-card:hover .nav-chevron {
    transform: translateX(3px);
    color: var(--sl-color-accent);
  }
</style>
