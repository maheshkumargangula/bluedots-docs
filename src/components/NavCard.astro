---
interface Props {
  title: string;
  description: string;
  href: string;
  icon: string;
  color: 'blue' | 'pink' | 'purple' | 'orange' | 'green';
}
const { title, description, href, icon, color } = Astro.props;
---

<a href={href} class:list={['nav-card', `nav-card--${color}`]}>
  <span class="nav-icon" aria-hidden="true">{icon}</span>
  <span class="nav-content">
    <span class="nav-title">{title}</span>
    <span class="nav-desc">{description}</span>
  </span>
  <span class="nav-arrow" aria-hidden="true">→</span>
</a>

<style>
  .nav-card {
    --nc: var(--dot-blue);
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem 1.375rem;
    border-radius: 0.875rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-top: 3px solid var(--nc);
    text-decoration: none;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.05);
    transition: transform 0.18s ease, box-shadow 0.18s ease;
  }
  .nav-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 22px color-mix(in srgb, var(--nc) 18%, transparent);
  }
  .nav-card--blue   { --nc: var(--dot-blue); }
  .nav-card--pink   { --nc: var(--dot-pink); }
  .nav-card--purple { --nc: var(--dot-purple); }
  .nav-card--orange { --nc: var(--dot-orange); }
  .nav-card--green  { --nc: var(--dot-green); }

  .nav-icon {
    font-size: 1.5rem;
    width: 2.75rem;
    height: 2.75rem;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.5rem;
    background: color-mix(in srgb, var(--nc) 10%, transparent);
  }

  .nav-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .nav-title {
    font-weight: 700;
    font-size: 1rem;
    color: var(--sl-color-text);
    line-height: 1.3;
  }

  .nav-desc {
    font-size: 0.875rem;
    color: var(--sl-color-gray-2);
    line-height: 1.45;
  }

  .nav-arrow {
    font-size: 1.125rem;
    color: var(--nc);
    flex-shrink: 0;
    transition: transform 0.18s ease;
  }

  .nav-card:hover .nav-arrow {
    transform: translateX(5px);
  }
</style>
