---
interface Props {
  before: string;
  after: string;
  persona?: string;
}
const { before, after, persona } = Astro.props;
---

<div class="jq">
  {persona && <div class="jq-persona">{persona}</div>}
  <div class="jq-bubbles">
    <div class="jq-bubble jq-before">
      <span class="jq-tag">Before</span>
      <p class="jq-text">"{before}"</p>
    </div>
    <div class="jq-arrow" aria-hidden="true">→</div>
    <div class="jq-bubble jq-after">
      <span class="jq-tag">After</span>
      <p class="jq-text">"{after}"</p>
    </div>
  </div>
</div>

<style>
  .jq {
    margin-block: 1.5rem;
  }
  .jq-persona {
    font-size: 0.8125rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--sl-color-gray-2);
    margin-bottom: 0.625rem;
  }
  .jq-bubbles {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 0.75rem;
    align-items: stretch;
  }
  @media (max-width: 600px) {
    .jq-bubbles {
      grid-template-columns: 1fr;
    }
    .jq-arrow {
      padding-top: 0 !important;
      transform: rotate(90deg);
    }
  }
  .jq-bubble {
    padding: 1rem 1.125rem;
    border-radius: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .jq-before {
    background: hsl(0, 55%, 97%);
    border: 1px solid hsl(0, 50%, 88%);
  }
  .jq-after {
    background: hsl(142, 50%, 94%);
    border: 1px solid hsl(142, 45%, 83%);
  }
  :root[data-theme='dark'] .jq-before {
    background: hsl(0, 40%, 14%);
    border-color: hsl(0, 40%, 22%);
  }
  :root[data-theme='dark'] .jq-after {
    background: hsl(142, 35%, 12%);
    border-color: hsl(142, 35%, 20%);
  }
  .jq-tag {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .jq-before .jq-tag { color: hsl(0, 50%, 38%); }
  .jq-after  .jq-tag { color: hsl(142, 50%, 28%); }
  :root[data-theme='dark'] .jq-before .jq-tag { color: hsl(0, 60%, 72%); }
  :root[data-theme='dark'] .jq-after  .jq-tag { color: hsl(142, 60%, 65%); }

  .jq-text {
    font-size: 0.9375rem;
    font-style: italic;
    line-height: 1.5;
    margin: 0;
    color: var(--sl-color-text);
  }
  .jq-arrow {
    font-size: 1.5rem;
    color: var(--sl-color-gray-3);
    display: flex;
    align-items: center;
    justify-content: center;
  }
</style>
