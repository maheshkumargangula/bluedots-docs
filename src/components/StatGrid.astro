---
interface Props {
  minWidth?: string;
  cols?: number;
}
const { minWidth = '180px', cols } = Astro.props;
const gridStyle = cols
  ? `grid-template-columns: repeat(${cols}, 1fr)`
  : `--min: ${minWidth}`;
---

<div class="stat-grid" style={gridStyle}>
  <slot />
</div>

<style>
  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(var(--min, 180px), 1fr));
    gap: 1rem;
    margin-block: 1.5rem;
  }
</style>
